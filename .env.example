# HelixEMR Environment Configuration Example
# Copy to .env and fill in real values – do not commit .env to git

# Database
HELIX_DB_HOSTNAME=localhost
HELIX_DB_PORT=3306
HELIX_DB_NAME=helixemr
HELIX_DB_USERNAME=helixemr
HELIX_DB_PASSWORD=change_me_in_production

# Application admin
HELIX_ADMIN_USER_PASSWORD=Admin1234!

# Docker image tag
TAG=1.0.0

# JVM tuning (optional)
JAVA_OPTS=-Xmx1g -Xms512m -server
