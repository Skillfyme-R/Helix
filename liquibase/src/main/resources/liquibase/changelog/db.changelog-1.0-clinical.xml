<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!-- ================================================================ -->
    <!--  HelixEMR 1.0 – Clinical: Encounter, Obs, Orders, Conditions    -->
    <!-- ================================================================ -->

    <!-- Encounter type -->
    <changeSet id="helix-1.0-050" author="helix-engineering">
        <createTable tableName="helix_encounter_type">
            <column name="encounter_type_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="varchar(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="name" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="description" type="text"/>
            <column name="retired" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Encounter -->
    <changeSet id="helix-1.0-051" author="helix-engineering">
        <createTable tableName="helix_encounter">
            <column name="encounter_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="varchar(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="patient_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_type" type="int"/>
            <column name="encounter_datetime" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="location_id" type="int"/>
            <column name="provider_id" type="int"/>
            <column name="visit_id" type="int"/>
            <column name="form_id" type="int"/>
            <column name="voided" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="voided_by" type="int"/>
            <column name="date_voided" type="datetime"/>
            <column name="void_reason" type="varchar(255)"/>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="changed_by" type="int"/>
            <column name="date_changed" type="datetime"/>
        </createTable>

        <addForeignKeyConstraint
            constraintName="fk_encounter_patient"
            baseTableName="helix_encounter"
            baseColumnNames="patient_id"
            referencedTableName="helix_patient"
            referencedColumnNames="patient_id"/>

        <createIndex tableName="helix_encounter" indexName="idx_encounter_patient">
            <column name="patient_id"/>
        </createIndex>
        <createIndex tableName="helix_encounter" indexName="idx_encounter_datetime">
            <column name="encounter_datetime"/>
        </createIndex>
    </changeSet>

    <!-- Observation -->
    <changeSet id="helix-1.0-060" author="helix-engineering">
        <createTable tableName="helix_obs">
            <column name="obs_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="varchar(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="person_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="concept_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_id" type="int"/>
            <column name="obs_datetime" type="datetime">
                <constraints nullable="false"/>
            </column>
            <column name="location_id" type="int"/>
            <column name="obs_group_id" type="int"/>
            <column name="value_boolean" type="boolean"/>
            <column name="value_coded" type="int"/>
            <column name="value_datetime" type="datetime"/>
            <column name="value_numeric" type="double"/>
            <column name="value_text" type="text"/>
            <column name="value_complex" type="varchar(1000)"/>
            <column name="comments" type="varchar(255)"/>
            <column name="voided" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex tableName="helix_obs" indexName="idx_obs_person_concept">
            <column name="person_id"/>
            <column name="concept_id"/>
        </createIndex>
    </changeSet>

    <!-- Condition -->
    <changeSet id="helix-1.0-070" author="helix-engineering">
        <createTable tableName="helix_condition">
            <column name="condition_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="varchar(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="patient_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="concept_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="condition_non_coded" type="varchar(1024)"/>
            <column name="clinical_status" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="verification_status" type="varchar(50)"/>
            <column name="onset_date" type="datetime"/>
            <column name="end_date" type="datetime"/>
            <column name="end_reason" type="varchar(1024)"/>
            <column name="voided" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <!-- Orders -->
    <changeSet id="helix-1.0-080" author="helix-engineering">
        <createTable tableName="helix_orders">
            <column name="order_id" type="int" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="uuid" type="varchar(38)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="order_type_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="patient_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="concept_id" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="encounter_id" type="int"/>
            <column name="orderer" type="int"/>
            <column name="date_activated" type="datetime"/>
            <column name="auto_expire_date" type="datetime"/>
            <column name="date_stopped" type="datetime"/>
            <column name="order_reason" type="int"/>
            <column name="order_reason_non_coded" type="varchar(255)"/>
            <column name="urgency" type="varchar(50)" defaultValue="ROUTINE"/>
            <column name="order_number" type="varchar(50)">
                <constraints unique="true"/>
            </column>
            <column name="instructions" type="text"/>
            <column name="voided" type="boolean" defaultValueBoolean="false">
                <constraints nullable="false"/>
            </column>
            <column name="date_created" type="datetime" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="creator" type="int">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

</databaseChangeLog>
